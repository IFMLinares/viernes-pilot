# Configuración del asistente Viernes Pilot

# URL de Ollama (puedes cambiar localhost por la IP de tu PC de trabajo si usas Tailscale)
OLLAMA_URL=http://localhost:11434

# Modelo principal para Chat y Tool Calling (ej. qwen3.5:9b, gemma2, etc.)
OLLAMA_MODEL=qwen3.5:9b

# Modelo para embeddings de memoria
OLLAMA_EMBED=nomic-embed-text

# URL de Engram para memoria a largo plazo
ENGRAM_URL=http://localhost:7437

# Nombre del proyecto en Engram
ENGRAM_PROJECT=viernes

